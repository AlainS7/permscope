{
  "name": "permscope",
  "displayName": "PermScope",
  "description": "Know what your code and AI tools are allowed to do. Highlights risky commands and explains their consequences.",
  "version": "0.1.0",
  "publisher": "alains7",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "security",
    "linter",
    "shell",
    "ai",
    "copilot",
    "yaml",
    "json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AlainS7/permscope"
  },
  "homepage": "https://github.com/AlainS7/permscope",
  "bugs": {
    "url": "https://github.com/AlainS7/permscope/issues"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "author": {
    "name": "Alain Soto",
    "url": "https://github.com/AlainS7"
  },
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "permscope.showRiskSummary",
        "title": "PermScope: Open Problems"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "verify:fixtures": "pnpm run compile && node ./tests/verify-fixtures.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
